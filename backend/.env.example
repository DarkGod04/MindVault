# Google AI Studio API Key (or GEMINI_API_KEY)
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Signing Secret (Random secure string)
JWT_SECRET=your_jwt_signing_secret_here

# Database connection URL (for Neon Postgres)
# Leave empty to default to local SQLite (data/mindvault.db)
DATABASE_URL=postgresql://user:password@ep-host-name.aws.neon.tech/neondb?sslmode=require

# Allowed CORS Origins (comma-separated list, e.g. for Vercel deployment)
CORS_ORIGINS=https://your-frontend-app.vercel.app,http://localhost:3000
